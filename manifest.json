{
  "manifest_version": 3,
  "name": "Shorts Speed Controller",
  "version": "1.0.1",
  "description": "Adjust and save playback speed for YouTube Shorts from the player controls.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
